rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    // UserType enum indices (see lib/models/clinic_models.dart)
    // petOwner=0, vet=1, clinicAdmin=2, appOwner=3
    function isAppOwner() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.userType == 3;
    }

    function isClinicMember(clinicId) {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/clinics/$(clinicId)/members/$(request.auth.uid));
    }

    // ClinicRole enum indices (admin=0, vet=1)
    function isClinicAdmin(clinicId) {
      return isSignedIn() &&
        get(/databases/$(database)/documents/clinics/$(clinicId)/members/$(request.auth.uid)).data.role == 0;
    }

    function isTempUser(userId) {
      return userId.matches('^temp_(admin|vet)_.+');
    }

    // Users and their subcollections
    match /users/{userId} {
      allow create: if isSignedIn() && (
        request.auth.uid == userId ||
        isAppOwner() ||
        (
          isTempUser(userId) &&
          request.resource.data.connectedClinicId != null &&
          isClinicAdmin(request.resource.data.connectedClinicId) &&
          request.resource.data.keys().hasOnly([
            'email',
            'displayName',
            'userType',
            'connectedClinicId',
            'clinicRole',
            'phone',
            'address',
            'hasSkippedClinicSelection',
            'createdAt',
            'updatedAt',
            'isActive'
          ])
        )
      );

      // Read rules: owner of doc, app owner, or matching email (temp profile linking)
      allow read: if isSignedIn() && (
        request.auth.uid == userId ||
        isAppOwner() ||
        (
          exists(/databases/$(database)/documents/users/$(userId)) &&
          get(/databases/$(database)/documents/users/$(userId)).data.email == request.auth.token.email
        )
      );

      allow update: if isSignedIn() && (
        request.auth.uid == userId ||
        isAppOwner() ||
        (
          request.resource.data.keys().hasOnly([
            'email',
            'userType',
            'clinicRole',
            'connectedClinicId',
            'updatedAt'
          ]) &&
          (
            (resource.data.connectedClinicId != null &&
              isClinicAdmin(resource.data.connectedClinicId)) ||
            (request.resource.data.connectedClinicId != null &&
              isClinicAdmin(request.resource.data.connectedClinicId))
          ) &&
          (
            (resource.data.userType != null && resource.data.userType == 1) ||
            (request.resource.data.userType != null && request.resource.data.userType == 1)
          )
        )
      );

      allow delete: if isSignedIn() && (request.auth.uid == userId || isAppOwner());

      match /events/{eventId} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }

      match /clinicHistory/{historyId} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }

      // User's pets subcollection
      match /pets/{petId} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }
    }

    // Clinics and members
    match /clinics/{clinicId} {
      // Allow discovery of active clinics to signed-in users; broader access for admins/app owner
      allow read: if (
        (isSignedIn() && resource.data.isActive == true) ||
        isClinicAdmin(clinicId) ||
        isAppOwner()
      );

      // Create clinic: app owner OR the creator sets themselves as admin
      allow create: if isSignedIn() && (
        isAppOwner() || request.resource.data.adminId == request.auth.uid
      );

      // Update/delete clinic: clinic admin or app owner
      allow update, delete: if isClinicAdmin(clinicId) || isAppOwner();

      match /members/{memberId} {
        allow read: if isAppOwner() || resource.data.isActive == true || isClinicMember(clinicId);
        allow create: if isAppOwner() || isClinicAdmin(clinicId);
        allow update: if isAppOwner() || (isClinicAdmin(clinicId) && (
            (resource.data.isActive == true &&
              request.resource.data.keys().hasOnly(['isActive', 'lastActive', 'permissions']))
          )
        );
        allow delete: if isAppOwner();
      }

      match /invites/{inviteId} {
        allow read: if isAppOwner() || isClinicAdmin(clinicId);
        allow create: if isAppOwner() || isClinicAdmin(clinicId);
        allow update: if isAppOwner() || (isClinicAdmin(clinicId) && isClinicMember(clinicId));
        allow delete: if isAppOwner() || isClinicAdmin(clinicId);
      }
    }

    // Chat rooms and messages (1:1: petOwnerId <-> vetId)
    match /chatRooms/{chatRoomId} {
      // Create: requester must be one of the participants
      allow create: if isSignedIn() && (
        request.resource.data.petOwnerId == request.auth.uid ||
        request.resource.data.vetId == request.auth.uid
      );

      // Read/update/delete: only participants may access the room
      allow read, update, delete: if isSignedIn() && (
        resource.data.petOwnerId == request.auth.uid ||
        resource.data.vetId == request.auth.uid
      );

      match /messages/{messageId} {
        allow create, read, update, delete: if isSignedIn() && (
          get(/databases/$(database)/documents/chatRooms/$(chatRoomId)).data.petOwnerId == request.auth.uid ||
          get(/databases/$(database)/documents/chatRooms/$(chatRoomId)).data.vetId == request.auth.uid
        );
      }
    }
  }
}
